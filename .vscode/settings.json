{
  "search.exclude": {
    "**/.next": true,
    "**/.git": true,
    "**/node_modules": true,
    "**/public/**/*.mp4": true,
    "**/public/**/*.jpg": true,
    "**/public/**/*.png": true,
    "**/public/**/*.webp": true,
    "**/build": true,
    "**/dist": true
